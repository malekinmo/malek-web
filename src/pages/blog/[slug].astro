---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { data } = post;
const { Content } = await render(post);
---
<BaseLayout title={data.title} description={data.excerpt} ogImage={data.coverImage}>
  <article class="section container post">
    <p class="date">{data.publishDate.toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' })} · {data.author}</p>
    <h1>{data.title}</h1>
    {data.coverImage && <img class="cover" src={data.coverImage} alt={data.title} />}
    <div class="prose"><Content /></div>
  </article>
</BaseLayout>

<style>
  .post { max-width: 760px; }
  .date { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--blue); margin-bottom: var(--space-2); }
  h1 { font-size: clamp(1.8rem, 4vw, 2.6rem); margin-bottom: var(--space-3); }
  .cover { width: 100%; aspect-ratio: 16/9; object-fit: cover; margin-bottom: var(--space-3); }
  .prose { color: var(--black); line-height: 1.8; font-size: 1.05rem; }
  .prose :global(h2) { font-size: 1.4rem; margin-top: var(--space-4); margin-bottom: var(--space-2); }
  .prose :global(p) { margin-bottom: 1.2em; }
</style>
