---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const properties = await getCollection('properties');
  return properties.map((p) => ({
    params: { slug: p.id },
    props: { property: p },
  }));
}

const { property } = Astro.props;
const { data } = property;
const { Content } = await render(property);

const waHref = `https://wa.me/${data.whatsappNumber}?text=${encodeURIComponent(data.whatsappMessage)}`;

// Convierte un link de YouTube/Vimeo "normal" en URL de embed.
function toEmbedUrl(url?: string): string | null {
  if (!url) return null;
  try {
    const u = new URL(url);
    if (u.hostname.includes('youtu.be')) {
      const id = u.pathname.replace('/', '');
      return `https://www.youtube.com/embed/${id}`;
    }
    if (u.hostname.includes('youtube.com')) {
      if (u.pathname.startsWith('/embed/')) return url;
      const id = u.searchParams.get('v');
      if (id) return `https://www.youtube.com/embed/${id}`;
    }
    if (u.hostname.includes('vimeo.com')) {
      if (u.hostname.includes('player.vimeo.com')) return url;
      const id = u.pathname.replace('/', '');
      return `https://player.vimeo.com/video/${id}`;
    }
    return url;
  } catch {
    return null;
  }
}

const videoEmbedUrl = toEmbedUrl(data.videoUrl);

// Todas las fotos (portada + galería) para el visor a pantalla completa.
const allPhotos = [data.coverImage, ...data.gallery];

const stats = [
  { label: 'Ambientes', value: data.ambientes },
  { label: 'Baños', value: data.banos },
  { label: 'Superficie', value: `${data.m2} m²` },
  { label: 'Orientación', value: data.orientacion ?? '—' },
  { label: 'Ubicación', value: data.ubicacion ?? '—' },
  { label: 'Antigüedad', value: data.antiguedad ? `${data.antiguedad} años` : '—' },
  { label: 'Expensas', value: data.expensas ? `$${data.expensas.toLocaleString('es-AR')}` : '—' },
  { label: 'ABL', value: data.abl ? `$${data.abl.toLocaleString('es-AR')}` : '—' },
];
---

<BaseLayout title={data.title} description={`${data.title} — ${data.barrio}. ${data.ambientes} ambientes, ${data.m2} m².`} ogImage={data.coverImage}>

  <section class="prop-hero">
    <button class="prop-hero-btn" data-lightbox-open data-index="0" aria-label="Ver foto a pantalla completa">
      <img src={data.coverImage} alt={data.title} />
    </button>
    <div class="prop-hero-overlay container">
      <p class="eyebrow" style="color: var(--blue-tint-3);">{data.barrio}</p>
      <h1>{data.title}</h1>
      <p class="price">USD {data.price.toLocaleString('es-AR')}</p>
    </div>
  </section>

  <section class="section container prop-body">
    <div class="prop-main">
      <h2>Sobre esta propiedad</h2>
      <div class="prose"><Content /></div>

      {data.gallery.length > 0 && (
        <>
          <h2 style="margin-top: var(--space-4);">Fotos</h2>
          <div class="gallery">
            {data.gallery.map((src, i) => (
              <button class="gallery-item" data-lightbox-open data-index={i + 1} aria-label={`Ver foto ${i + 1} a pantalla completa`}>
                <img src={src} alt={data.title} loading="lazy" />
              </button>
            ))}
          </div>
        </>
      )}

      {videoEmbedUrl && (
        <>
          <h2 style="margin-top: var(--space-4);">Video</h2>
          <div class="video-embed">
            <iframe
              src={videoEmbedUrl}
              title={`Video — ${data.title}`}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        </>
      )}

      {data.virtualTourUrl && (
        <>
          <h2 style="margin-top: var(--space-4);">Recorrido virtual</h2>
          <div class="tour-embed">
            <iframe
              src={data.virtualTourUrl}
              allow="xr-spatial-tracking; gyroscope; accelerometer"
              allowfullscreen
              loading="lazy"
              title={`Tour virtual — ${data.title}`}
            ></iframe>
          </div>
        </>
      )}
    </div>

    <aside class="prop-sidebar">
      <div class="stats-card">
        <h3>Detalles</h3>
        <dl>
          {stats.map((s) => (
            <div class="stat-row">
              <dt>{s.label}</dt>
              <dd>{s.value}</dd>
            </div>
          ))}
        </dl>
        <a href={waHref} class="btn btn-primary" style="width: 100%; justify-content: center; margin-top: var(--space-2);" target="_blank" rel="noopener">
          Agendar visita por WhatsApp
        </a>
      </div>
    </aside>
  </section>

  <!-- Visor de fotos a pantalla completa -->
  <div class="lightbox" data-lightbox hidden>
    <button class="lightbox-close" data-lightbox-close aria-label="Cerrar">✕</button>
    <button class="lightbox-nav lightbox-prev" data-lightbox-prev aria-label="Foto anterior">‹</button>
    <img class="lightbox-img" data-lightbox-img src="" alt="" />
    <button class="lightbox-nav lightbox-next" data-lightbox-next aria-label="Foto siguiente">›</button>
    <p class="lightbox-counter" data-lightbox-counter></p>
  </div>

  <script define:vars={{ photos: allPhotos, title: data.title }}>
    const lightbox = document.querySelector('[data-lightbox]');
    const imgEl = document.querySelector('[data-lightbox-img]');
    const counterEl = document.querySelector('[data-lightbox-counter]');
    let currentIndex = 0;

    function openLightbox(index) {
      currentIndex = index;
      updateLightbox();
      lightbox.hidden = false;
      document.body.style.overflow = 'hidden';
    }
    function closeLightbox() {
      lightbox.hidden = true;
      document.body.style.overflow = '';
    }
    function updateLightbox() {
      imgEl.src = photos[currentIndex];
      imgEl.alt = title;
      counterEl.textContent = `${currentIndex + 1} / ${photos.length}`;
    }
    function nextPhoto() {
      currentIndex = (currentIndex + 1) % photos.length;
      updateLightbox();
    }
    function prevPhoto() {
      currentIndex = (currentIndex - 1 + photos.length) % photos.length;
      updateLightbox();
    }

    document.querySelectorAll('[data-lightbox-open]').forEach((btn) => {
      btn.addEventListener('click', () => {
        openLightbox(Number(btn.getAttribute('data-index')));
      });
    });
    document.querySelector('[data-lightbox-close]')?.addEventListener('click', closeLightbox);
    document.querySelector('[data-lightbox-next]')?.addEventListener('click', nextPhoto);
    document.querySelector('[data-lightbox-prev]')?.addEventListener('click', prevPhoto);
    lightbox?.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox();
    });
    document.addEventListener('keydown', (e) => {
      if (lightbox.hidden) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowRight') nextPhoto();
      if (e.key === 'ArrowLeft') prevPhoto();
    });
  </script>

</BaseLayout>

<style>
  .prop-hero { position: relative; height: min(60vh, 520px); overflow: hidden; }
  .prop-hero-btn { all: unset; display: block; width: 100%; height: 100%; cursor: zoom-in; }
  .prop-hero img { width: 100%; height: 100%; object-fit: cover; }
  .prop-hero-overlay {
    position: absolute;
    inset: 0;
    top: auto;
    padding-block: var(--space-4);
    background: linear-gradient(0deg, rgba(0,0,0,0.75), transparent 70%);
    color: var(--white);
    pointer-events: none;
  }
  .prop-hero-overlay h1 { font-size: clamp(1.8rem, 4vw, 3rem); color: var(--white); }
  .prop-hero-overlay .price { font-weight: 700; font-size: 1.3rem; margin-top: 0.4rem; color: var(--white); }

  .prop-body { display: grid; grid-template-columns: 2fr 1fr; gap: var(--space-5); align-items: start; }
  .prop-main h2 { font-size: 1.4rem; margin-bottom: var(--space-2); }
  .prose { color: var(--gray-900); line-height: 1.7; }

  .gallery { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-2); }
  .gallery-item { all: unset; display: block; cursor: zoom-in; }
  .gallery-item img { aspect-ratio: 4/3; object-fit: cover; }

  .video-embed, .tour-embed { aspect-ratio: 16/9; }
  .video-embed iframe, .tour-embed iframe { width: 100%; height: 100%; border: 0; }

  .stats-card {
    position: sticky;
    top: calc(var(--space-3) + 60px);
    border: 1px solid var(--gray-100);
    padding: var(--space-3);
  }
  .stats-card h3 { font-size: 1.1rem; margin-bottom: var(--space-2); }
  .stat-row { display: flex; justify-content: space-between; padding-block: 0.5rem; border-bottom: 1px solid var(--gray-100); font-size: 0.92rem; }
  .stat-row dt { color: var(--gray-900); }
  .stat-row dd { margin: 0; font-weight: 700; }

  .lightbox {
    position: fixed;
    inset: 0;
    background: rgba(10,10,10,0.95);
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .lightbox-img { max-width: 90vw; max-height: 85vh; object-fit: contain; }
  .lightbox-close, .lightbox-nav {
    position: absolute;
    background: rgba(255,255,255,0.1);
    color: var(--white);
    border: 0;
    cursor: pointer;
    display: grid;
    place-items: center;
  }
  .lightbox-close {
    top: var(--space-2);
    right: var(--space-2);
    width: 44px; height: 44px;
    font-size: 1.2rem;
    border-radius: 50%;
  }
  .lightbox-nav {
    top: 50%;
    transform: translateY(-50%);
    width: 52px; height: 52px;
    font-size: 2rem;
    border-radius: 50%;
  }
  .lightbox-prev { left: var(--space-2); }
  .lightbox-next { right: var(--space-2); }
  .lightbox-counter {
    position: absolute;
    bottom: var(--space-2);
    left: 50%;
    transform: translateX(-50%);
    color: var(--gray-400);
    font-size: 0.85rem;
    margin: 0;
  }

  @media (max-width: 900px) {
    .prop-body { grid-template-columns: 1fr; }
    .gallery { grid-template-columns: repeat(2, 1fr); }
    .stats-card { position: static; }
  }
</style>
