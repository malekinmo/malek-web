---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container grid">
    <div class="col-brand">
      <img src="/images/logo-malek-white.png" alt="Malek Inmobiliaria" height="32" />
      <p>Vendé tu casa al mayor valor, en el menor tiempo.</p>
    </div>

    <div class="col">
      <p class="eyebrow" style="color: var(--blue-tint-3);">Navegación</p>
      <ul>
        <li><a href="/#vender">Vender mi propiedad</a></li>
        <li><a href="/propiedades">Propiedades</a></li>
        <li><a href="/blog">Blog</a></li>
      </ul>
    </div>

    <div class="col">
      <p class="eyebrow" style="color: var(--blue-tint-3);">Contacto</p>
      <ul>
        <li><a href="https://wa.me/5491122540182" target="_blank" rel="noopener">WhatsApp</a></li>
        <li><a href="mailto:info@malek.com.ar">info@malek.com.ar</a></li>
        <li><a href="https://instagram.com/malekinmobiliaria" target="_blank" rel="noopener">Instagram</a></li>
      </ul>
    </div>
  </div>
  <div class="container">
    <p class="legal">© {year} Malek Inmobiliaria. Todos los derechos reservados.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--black);
    color: var(--white);
    padding-block: var(--space-5) var(--space-3);
    margin-top: var(--space-6);
  }
  .grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid rgba(255,255,255,0.15);
  }
  .col-brand p { color: var(--gray-400); margin-top: var(--space-2); max-width: 30ch; }
  .col ul { list-style: none; margin: var(--space-2) 0 0; padding: 0; display: grid; gap: 0.6rem; }
  .col a { color: var(--gray-400); font-size: 0.92rem; }
  .col a:hover { color: var(--blue); }
  .legal { color: var(--gray-900); font-size: 0.8rem; padding-top: var(--space-3); }

  @media (max-width: 720px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
