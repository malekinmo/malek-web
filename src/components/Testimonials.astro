---
interface Testimonial {
  name: string;
  quote: string;
}

// Sumamos más acá a medida que Jaco los vaya mandando.
const testimonials: Testimonial[] = [
  { name: 'Daniel', quote: 'Muy profesional, todo lo tuyo es para recomendar.' },
];
---

<section class="section testimonials">
  <div class="container">
    <p class="eyebrow">Testimonios</p>
    <h2 class="section-title">Lo que dicen quienes ya vendieron conmigo</h2>
    <div class="t-grid" data-count={testimonials.length}>
      {testimonials.map((t) => (
        <blockquote class="t-card">
          <p class="t-mark" aria-hidden="true">&ldquo;</p>
          <p class="t-quote">{t.quote}</p>
          <footer class="t-name">{t.name}</footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials { background: var(--blue-tint-1); }
  .section-title { font-size: clamp(1.6rem, 3vw, 2.2rem); margin-block: var(--space-2) var(--space-4); }
  .t-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-3);
  }
  .t-card {
    background: var(--white);
    padding: var(--space-3);
    margin: 0;
    border-top: 3px solid var(--blue);
  }
  .t-mark {
    font-family: var(--font-display);
    font-size: 3rem;
    color: var(--blue-tint-3);
    line-height: 1;
    margin: 0;
  }
  .t-quote { font-size: 1.05rem; color: var(--black); margin: 0.5rem 0 var(--space-2); }
  .t-name { font-weight: 700; font-size: 0.9rem; color: var(--gray-900); }
</style>
