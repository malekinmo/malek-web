---
interface Props {
  number?: string;
  message?: string;
}
const {
  number = '5491122540182',
  message = 'Hola! Quiero más información.',
} = Astro.props;

const href = `https://wa.me/${number}?text=${encodeURIComponent(message)}`;
---

<a class="wa-float" href={href} target="_blank" rel="noopener" aria-label="Escribinos por WhatsApp">
  <svg width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.39 1.26 4.81L2 22l5.42-1.36a9.87 9.87 0 0 0 4.62 1.15h.01c5.46 0 9.9-4.45 9.9-9.91C21.95 6.45 17.5 2 12.04 2Zm0 18.06h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.8.83-3.03-.2-.31a8.15 8.15 0 0 1-1.26-4.29c0-4.52 3.7-8.2 8.24-8.2a8.2 8.2 0 0 1 8.22 8.2c0 4.52-3.7 8.16-8.23 8.16Zm4.5-6.13c-.25-.12-1.46-.72-1.68-.8-.23-.08-.39-.12-.56.12-.16.25-.64.8-.79.96-.14.16-.29.18-.54.06-.25-.12-1.04-.38-1.98-1.21-.73-.65-1.22-1.46-1.37-1.7-.14-.25-.02-.39.11-.51.11-.11.25-.29.37-.43.12-.14.16-.25.24-.41.08-.16.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.83-.2-.48-.4-.42-.56-.42-.14 0-.31-.02-.47-.02-.16 0-.43.06-.66.31-.23.25-.86.84-.86 2.05 0 1.21.88 2.38 1 2.54.12.16 1.73 2.64 4.19 3.7.59.25 1.04.4 1.4.52.59.19 1.12.16 1.54.1.47-.07 1.46-.6 1.66-1.18.21-.58.21-1.07.14-1.18-.06-.1-.22-.16-.47-.28Z" fill="currentColor"/>
  </svg>
</a>

<style>
  .wa-float {
    position: fixed;
    right: var(--space-3);
    bottom: var(--space-3);
    width: 56px;
    height: 56px;
    display: grid;
    place-items: center;
    background: #25D366;
    color: var(--white);
    border-radius: 50%;
    box-shadow: 0 8px 20px rgba(0,0,0,0.25);
    z-index: 60;
    transition: transform 0.15s ease;
  }
  .wa-float:hover { transform: scale(1.06); }
  .wa-float:focus-visible { outline: 2px solid var(--blue); outline-offset: 3px; }
</style>
